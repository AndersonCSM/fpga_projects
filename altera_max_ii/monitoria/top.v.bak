module top (
    input  wire clk,   // clock do seu board (ex: 50 MHz)
    output reg led
);

    reg [24:0] cnt;
    
    always @(posedge clk) begin
        if (cnt == 25_000_000 - 1) begin
            cnt <= 0;
            led <= ~led;
        end else begin
            cnt <= cnt + 1;
        end
    end
    
endmodule